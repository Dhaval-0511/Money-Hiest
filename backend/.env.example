# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=expense_tracker
PGUSER=expense_tracker_app
PGPASSWORD=change_this_password
PG_SSL=false            # set true when using a managed cloud Postgres (e.g. Render/RDS/Supabase)

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_64+_char_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5500

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOGIN_RATE_LIMIT_MAX=10
